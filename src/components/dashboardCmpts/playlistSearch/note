const handlePlaylistSearch = async (event: React.FormEvent) => {
    event.preventDefault()
    setLoading(true)

    const safeOffsets = [0, 50, 100, 150, 200] 
    const randomOffset = safeOffsets[Math.floor(Math.random() * safeOffsets.length)]

    const searchOptions = {
      method: 'GET',
      url: 'https://spotify23.p.rapidapi.com/search/',
      params: {
        q: searchData,
        type: 'playlists',
        offset: randomOffset.toString(),
        limit: '5',
        numberOfTopResults: randomOffset.toString(),
      },
      headers: {
        'x-rapidapi-key': process.env.NEXT_PUBLIC_RAPID_API_KEY_SPOTIFY,
        'x-rapidapi-host': process.env.NEXT_PUBLIC_RAPID_API_HOST
      }
    }

    try {
      const searchResponse = await axios.request(searchOptions)
      const items = searchResponse.data?.playlists?.items ?? []

      // Get playlist IDs
      const playlistIDs = items.map((item: any) => item?.data?.uri?.split(':').pop())

      // Fetch full details for each playlist
      const detailRequests = playlistIDs.map((id: string) => {
        return axios.request({
          method: 'GET',
          url: 'https://spotify23.p.rapidapi.com/playlist/',
          params: { id },
          headers: {
            'x-rapidapi-key': process.env.NEXT_PUBLIC_RAPID_API_KEY_SPOTIFY,
            'x-rapidapi-host': process.env.NEXT_PUBLIC_RAPID_API_HOST
          }
        })
      })

      const detailedResponses = await Promise.all(detailRequests)
      const fullPlaylists = detailedResponses.map(res => res.data)
      setPlaylists(fullPlaylists)
      setSearchData("")
      setIntroState(false)
      setChangeInput(true)

    } catch (err) {
      console.error(err)
    } finally {
      setLoading(false)
    }
  }